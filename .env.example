# RouteLog — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# A long random string used to sign session cookies.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_this_with_a_long_random_string

# Your Google OAuth Client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=210103213011-310sqa00pg7n51iuvgcao14lu1of67kn.apps.googleusercontent.com

# Password for the PostgreSQL database.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(16))"
DB_PASSWORD=replace_this_with_a_strong_password

# Comma-separated list of origins allowed to call the API.
# This is your GitHub Pages URL (and localhost for testing).
ALLOWED_ORIGINS=https://robscode96.github.io,http://localhost
